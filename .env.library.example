# Copy to .env.library on the droplet (same pattern as Valmiki .env.valmiki)
#
# Library client: http://139.59.6.209:5002
# Library API:    http://139.59.6.209:5003

CLIENT_URL=http://139.59.6.209:5002
REACT_APP_API_URL=http://139.59.6.209:5003/api

JWT_SECRET=change-me-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
TRUST_PROXY=false

# Aiven PostgreSQL (external — not in Docker like Valmiki Mongo)
DB_PROFILE=online
DATABASE_URL=postgres://avnadmin:PASSWORD@HOST:PORT/library_db?sslmode=require
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# First deploy only — remove after admin login works
SEED_ADMIN_PASSWORD=ChangeMe@123

# HTTP deploy (no SSL yet) — required for login cookies on http://IP:port
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
