PORT=5000
DB_PROFILE=online

# Connection URL (Aiven PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/library_db?sslmode=require

DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Or use separate fields instead of DATABASE_URL:
# DB_HOST=your-host.aivencloud.com
# DB_PORT=5432
# DB_USER=avnadmin
# DB_PASSWORD=your_password
# DB_NAME=library_db
