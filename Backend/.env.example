PORT=5000
NODE_ENV=development

JWT_SECRET=your-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m

# Comma-separated allowed frontend origins
CORS_ORIGINS=http://localhost:3000

# Set to true when running behind a reverse proxy (nginx, Railway, Render, etc.)
TRUST_PROXY=false

# Only used on first migration to create admin if missing (never commit real password)
SEED_ADMIN_PASSWORD=ChangeMe@123
# One-time password for legacy member migration only
SEED_TEMP_PASSWORD=Temp@123

DB_PROFILE=online

# Connection URL (Aiven PostgreSQL)
DATABASE_URL=postgres://user:password@host:5432/library_db?sslmode=require

DB_SSL=true
# Set to true in production when your CA is trusted; false only for managed DBs with self-signed certs
DB_SSL_REJECT_UNAUTHORIZED=false

# Or use separate fields instead of DATABASE_URL:
# DB_HOST=your-host.aivencloud.com
# DB_PORT=5432
# DB_USER=avnadmin
# DB_PASSWORD=your_password
# DB_NAME=library_db
