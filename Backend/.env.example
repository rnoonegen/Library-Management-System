PORT=5000

# Database profile: memory | local | online
# memory  = no MySQL (sample in-memory data)
# local   = MySQL installed on your computer
# online  = shared cloud MySQL (for team development)
DB_PROFILE=memory

# --- Local MySQL settings (when DB_PROFILE=local) ---
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=Rnoone@123
DB_NAME=library_db

# --- Online MySQL settings (when DB_PROFILE=online) ---
# Option A: use a connection URL from Railway, Aiven, etc.
# DATABASE_URL=mysql://user:password@host:3306/library_db

# Option B: use separate fields
# DB_HOST=your-cloud-host.example.com
# DB_PORT=3306
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=library_db
# DB_SSL=true
