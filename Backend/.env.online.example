PORT=5000
DB_PROFILE=online

# Use the shared team database credentials here.
# Copy this file to .env and fill in values from your cloud provider.

# Option A: connection URL (Railway, Aiven, etc.)
DATABASE_URL=mysql://user:password@host:3306/library_db

# Option B: separate fields (uncomment if not using DATABASE_URL)
# DB_HOST=your-cloud-host.example.com
# DB_PORT=3306
# DB_USER=your_user
# DB_PASSWORD=your_password
# DB_NAME=library_db

# SSL is usually required for online MySQL
DB_SSL=true
