# API base URL (optional — defaults to /api which uses the dev proxy)
# REACT_APP_API_URL=http://localhost:5000/api

# Production — IP deploy (set in server /opt/library/.env, not here):
# REACT_APP_API_URL=http://139.59.6.209:5000/api

# Production — domain with Nginx (same origin):
# REACT_APP_API_URL=/api
