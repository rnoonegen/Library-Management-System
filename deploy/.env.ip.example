# Server .env for Library app on port 5000 (docker-compose.ip.yml)
# Copy to /opt/library/.env on droplet — NEVER commit the real file

NODE_ENV=production
PORT=5000

JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=15m

# Same origin — users open http://139.59.6.209:5002
# (Port 5000 is used by valmiki-server on this droplet)
CORS_ORIGINS=http://139.59.6.209:5002
TRUST_PROXY=true

# Aiven PostgreSQL
DB_PROFILE=online
DATABASE_URL=postgres://avnadmin:PASSWORD@HOST:PORT/library_db?sslmode=require
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# First deploy only — remove after admin login works
SEED_ADMIN_PASSWORD=ChangeMe@123

# Same-origin API (baked into frontend at docker build)
REACT_APP_API_URL=/api
