# Production environment template for /opt/library/.env on the server
# Copy to .env on the droplet — NEVER commit the real .env file

# Backend
NODE_ENV=production
PORT=5000
JWT_SECRET=replace-with-64-char-random-string
JWT_EXPIRES_IN=15m
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
TRUST_PROXY=true

# Aiven PostgreSQL
DB_PROFILE=online
DATABASE_URL=postgres://avnadmin:PASSWORD@HOST:PORT/library_db?sslmode=require
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# First deploy only — remove after admin user exists
SEED_ADMIN_PASSWORD=ChangeMe@123

# Frontend build arg (baked into static bundle at build time)
REACT_APP_API_URL=/api
